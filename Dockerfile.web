FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_PRIVATE_SUPPORT_QQ
ARG VITE_PRIVATE_SUPPORT_WECHAT
ENV VITE_PRIVATE_SUPPORT_QQ=$VITE_PRIVATE_SUPPORT_QQ
ENV VITE_PRIVATE_SUPPORT_WECHAT=$VITE_PRIVATE_SUPPORT_WECHAT

COPY web/package*.json ./
RUN npm ci

COPY web/ ./
RUN npm run build

FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
